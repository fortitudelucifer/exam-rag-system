# ─── RAGFlow 连接 ──────────────────────────────────────────────
# RAGFlow Web UI 地址（Docker 部署后默认 http://127.0.0.1）
RAGFLOW_URL=http://127.0.0.1

# RAGFlow API Key（从 RAGFlow UI → 右上角头像 → API Key 获取）
RAGFLOW_API_KEY=your_ragflow_api_key_here

# RAGFlow 容器名（用于密码加密登录，默认即可）
RAGFLOW_CONTAINER=docker-ragflow-cpu-1

# ─── Embedding / Reranker 服务地址 ─────────────────────────────
# 如果使用 VLLM 本地部署 Qwen3-Embedding-4B / Qwen3Reranker4B
EMBEDDING_BASE_URL=http://your-host:8011/v1
EMBEDDING_MODEL=Qwen3-Embedding-4B
RERANKER_BASE_URL=http://your-host:8012/v1
RERANKER_MODEL=Qwen3Reranker4B

# ─── LLM Chat 模型 ─────────────────────────────────────────────
# 可选：通义千问 / DeepSeek / OpenAI 兼容接口
# 在 RAGFlow UI → Settings → Model Providers 中配置
CHAT_MODEL=qwen3-max@Tongyi-Qianwen

# ─── OCR 环境（PP-StructureV3）──────────────────────────────────
# PaddleOCR GPU 推理无需环境变量，但需要：
#   paddlepaddle-gpu==3.2.2 (CUDA 12.x)
#   paddleocr==3.4.0
#   paddlex==3.4.2
# 详见 docs/ocr-setup.md
